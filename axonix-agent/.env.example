# Axonix Agent Configuration
# Copy to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram Chat ID (send a message to your bot, then check https://api.telegram.org/bot<TOKEN>/getUpdates)
TELEGRAM_CHAT_ID=your_chat_id_here

# Path to the Charter-Legacy repo root
REPO_PATH=c:/Charter-Legacy v4

# Auto mode: if true, agent picks tasks automatically. If false, waits for commands.
AUTO_MODE=false

# Polling interval in minutes (how often the agent checks for new tasks in auto mode)
POLL_INTERVAL_MINUTES=30

# Max files the agent can modify per task
MAX_FILES_PER_TASK=3

# Git branch prefix for agent work
BRANCH_PREFIX=axonix

# Dev branch to merge approved work into
TARGET_BRANCH=dev
